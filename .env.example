# Copy this file to ".env" and fill in your values (local use).
# On Render, set these SAME names in the dashboard: Environment -> Secret Files / Environment Variables.

# Gmail sender credentials (App Password, NOT your normal password)
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# Optional: default Google Sheet URLs (you can also set these in the app's Settings page)
BASIC_SHEET_URL=
MAIN_SHEET_URL=
